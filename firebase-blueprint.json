        "direccion": { "type": "string" },
        "terminos": { "type": "string" }
      }
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "An order placed to a vendor.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "vendorId": { "type": "string" },
        "fechaCreacion": { "type": "number" },
        "fechaEsperada": { "type": "number" },
        "fechaRecepcion": { "type": "number" },
        "estado": { "type": "string" },
        "articulos": { "type": "string" },
        "total": { "type": "number" },
        "notas": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "checkNumber": { "type": "string" }
      }
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Inventory records.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "proveedor": { "type": "string" },
        "fecha": { "type": "number" },
        "factura": { "type": "string" },
        "articulos": { "type": "number" },
        "total": { "type": "number" },
        "estado": { "type": "string" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product category.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" }
      }
    },
    "Tax": {
      "title": "Tax",
      "description": "Tax rate.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" },
        "porcentaje": { "type": "number" }
      }
    },
    "Device": {
      "title": "Device",
      "description": "Device configuration.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" },
        "tipo": { "type": "string" },
        "conexion": { "type": "string" },
        "direccion": { "type": "string" },
        "activo": { "type": "boolean" }
      }
    }
