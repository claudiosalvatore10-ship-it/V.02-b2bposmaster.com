{
  "entities": {
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Global settings for the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "licenseKey": { "type": "string" },
        "isActive": { "type": "boolean" },
        "nombre": { "type": "string" },
        "direccion": { "type": "string" },
        "email": { "type": "string" },
        "telefono": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "A product available for sale.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "upc": { "type": "string" },
        "nombre": { "type": "string" },
        "precio": { "type": "number" },
        "costo": { "type": "number" },
        "categoria": { "type": "string" },
        "sku": { "type": "string" },
        "lote": { "type": "string" },
        "vencimiento": { "type": "string" },
        "stock": { "type": "number" },
        "componenteActivo": { "type": "string" },
        "laboratorio": { "type": "string" },
        "unidad": { "type": "string" },
        "imagenUrl": { "type": "string" },
        "descuento": { "type": "number" }
      }
    },
    "Client": {
      "title": "Client",
      "description": "A customer who places orders.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "ciudad": { "type": "string" },
        "estado": { "type": "string" },
        "cp": { "type": "string" },
        "email": { "type": "string" },
        "vendedorAsignado": { "type": "string" },
        "terminosCredito": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "A user of the system.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "codigo": { "type": "string" },
        "email": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "ciudad": { "type": "string" },
        "estado": { "type": "string" },
        "cp": { "type": "string" },
        "taxId": { "type": "string" },
        "activo": { "type": "boolean" },
        "pin": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "Salesman": {
      "title": "Salesman",
      "description": "A field agent who takes orders.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "codigo": { "type": "string" },
        "email": { "type": "string" },
        "telefono": { "type": "string" },
        "direccion": { "type": "string" },
        "ciudad": { "type": "string" },
        "estado": { "type": "string" },
        "cp": { "type": "string" },
        "taxId": { "type": "string" },
        "activo": { "type": "boolean" },
        "pin": { "type": "string" },
        "role": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer or salesman.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "proveedor": { "type": "string" },
        "fecha": { "type": "number" },
        "factura": { "type": "string" },
        "articulos": { "type": "string" },
        "total": { "type": "number" },
        "estado": { "type": "string" },
