  "firestore": {
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/StoreSettings" },
      "description": "Store settings."
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products."
    },
    "/clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "Clients."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users."
    },
    "/salesmen/{salesmanId}": {
      "schema": { "$ref": "#/entities/Salesman" },
      "description": "Salesmen."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders."
    },
    "/vendors/{vendorId}": {
      "schema": { "$ref": "#/entities/Vendor" },
      "description": "Vendors."
    },
    "/purchaseOrders/{poId}": {
      "schema": { "$ref": "#/entities/PurchaseOrder" },
      "description": "Purchase Orders."
    },
    "/inventory/{inventoryId}": {
      "schema": { "$ref": "#/entities/Inventory" },
      "description": "Inventory."
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories."
    },
    "/taxes/{taxId}": {
      "schema": { "$ref": "#/entities/Tax" },
      "description": "Taxes."
    },
    "/devices/{deviceId}": {
      "schema": { "$ref": "#/entities/Device" },
      "description": "Devices."
    }
  }
}
